---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormContact from '../components/FormContact.astro';
---

<BaseLayout title="Contact Us — The F.A.M. Project" description="Get in touch with The F.A.M. Project. We'd love to hear from you about partnerships, events, or how we can help strengthen your family.">
  <!-- Header -->
  <section class="py-16 md:py-24 bg-fam-blue text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Contact Us</h1>
      <p class="text-xl text-gray-200">We'd love to hear from you.</p>
    </div>
  </section>

  <!-- Contact Form & Info -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-fam-blue mb-6">Send Us a Message</h2>
          <FormContact buttonText="Let's change the world!" />
        </div>

        <!-- Contact Information -->
        <div>
          <h2 class="text-2xl font-bold text-fam-blue mb-6">Get in Touch</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold text-fam-text mb-2">The F.A.M. Project</h3>
              <p class="text-fam-text-light">
                We're a nonprofit organization dedicated to strengthening families through education, community events, and resources.
              </p>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-fam-text mb-2">Email</h3>
              <a href="mailto:info@thefamproject.com" class="text-fam-orange no-underline hover:text-fam-orange-dark">
                info@thefamproject.com
              </a>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-fam-text mb-2">Follow Us</h3>
              <div class="flex gap-4">
                <a href="https://www.facebook.com/thefamproject" target="_blank" rel="noopener noreferrer" class="text-fam-text-light hover:text-fam-orange transition-colors no-underline">Facebook</a>
                <a href="https://www.instagram.com/thefamproject/" target="_blank" rel="noopener noreferrer" class="text-fam-text-light hover:text-fam-orange transition-colors no-underline">Instagram</a>
                <a href="https://www.youtube.com/@thefamproject" target="_blank" rel="noopener noreferrer" class="text-fam-text-light hover:text-fam-orange transition-colors no-underline">YouTube</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
