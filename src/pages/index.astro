---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import FormNewsletter from '../components/FormNewsletter.astro';
import FormContact from '../components/FormContact.astro';
import CloudsCTA from '../components/CloudsCTA.astro';
import StatBlock from '../components/StatBlock.astro';
import Testimonial from '../components/Testimonial.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { Image } from 'astro:assets';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, SOCIAL_LINKS } from '../consts';
import heroImage from '../assets/hero/home-header-2.jpg';
import oneWorldImg from '../assets/misc/one-world.png';
import statPhoneUseImg from '../assets/misc/stat-phone-use.png';
import didYouKnowImg from '../assets/misc/did-you-know.png';
import didYouKnowBgImg from '../assets/hero/did-you-know-screens.jpg';
import famtopiaLogo from '../assets/projects/famtopia-logo.png';
import sunburstBg from '../assets/hero/sunburst-background.jpg';
import purpleGrungeBg from '../assets/hero/purple-grunge.jpg';
import famFunPassLogo from '../assets/projects/fam-funpass-logo.png';
import famCentralLogo from '../assets/projects/fam-central-logo.png';
import famCentralApp from '../assets/projects/fam-central-app.jpg';
import famCentralIcon from '../assets/projects/fam-central-icon.png';
import jashinMedallion from '../assets/team/jashin-howell-medallion.png';
import homeHeaderBg from '../assets/hero/home-header.jpg';


const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'The F.A.M. Project',
  url: SITE_URL,
  logo: `${SITE_URL}/favicon-192x192.png`,
  sameAs: [SOCIAL_LINKS.facebook, SOCIAL_LINKS.instagram, SOCIAL_LINKS.youtube],
};
---

<BaseLayout title={`${SITE_TITLE} — Disconnect to Connect`} description="Raising awareness surrounding the technological addictions that are destroying family bonds through smartphones, social media, and other digital devices.">
  <!-- Organization JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <!-- Hero Section -->
  <HeroSection
    title=""
    subtitle=""
    backgroundImage={heroImage}
    backgroundAlt="Families enjoying time together at a F.A.M. Project event"
    overlayClass="bg-purple-900/87"
    maxWidth="max-w-7xl"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center w-full max-w-6xl mx-auto px-4">
      <!-- Left: One World image + tagline -->
      <div class="text-left">
        <Image
          src={oneWorldImg}
          alt="One World, one big F.A.M."
          class="w-full mb-6"
          widths={[300, 500, 716]}
          sizes="(max-width: 768px) 80vw, 40vw"
        />
        <p class="text-white text-xl md:text-2xl font-light leading-snug">
          The <strong>Family Awareness Movement</strong> is healing hearts and homes by meeting the needs of modern day families.
        </p>
      </div>

      <!-- Right: Newsletter signup -->
      <div class="border border-purple-300/50 rounded-lg p-6 md:p-8 text-center">
        <div class="text-orange-400 text-2xl mb-3">★</div>
        <h2 class="text-white text-3xl md:text-4xl font-semibold mb-4 drop-shadow-lg">Get Involved!</h2>
        <p class="text-white text-lg font-light leading-snug mb-6">
          Subscribe to our <strong>FAMatics Newsletter</strong> to get insider access to freebies, family articles and resources, events, projects, <em>and more!</em>
        </p>
        <FormNewsletter buttonText="Let's change the world!" rowBreakpoint="xl:flex-row" />
      </div>
    </div>
  </HeroSection>

  <!-- Mission Section -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16 items-center">
        <!-- Left: Text content -->
        <div>
          <h2 class="text-3xl md:text-4xl font-semibold text-fam-purple mb-6">We're on a mission to heal and empower strong families</h2>
          <p class="text-fam-text-light leading-relaxed mb-4">
            <strong><em>Our Passion and Purpose is to Connect Families through Fun and Authentic Transformation!</em></strong>
          </p>
          <p class="text-fam-text-light leading-relaxed mb-4">
            The FAM Project was started by a group of families tired of losing their kids attention to devices and social media. F.A.M. stands for Family Awareness Movement, and we are committed to shining a light so bright on the effects and issues surrounding the technological addictions that are destroying family bonds and leading children down dark paths, alone.
          </p>
          <p class="text-fam-text-light leading-relaxed mb-6">
            And parents aren't faring much better! We live and work in the 21st century. The advent of the internet, smart phones, and social media has put our careers and lives into hyperdrive. Constant notifications, overstimulation, and information at our fingertips, it doesn't stop! And that's not going to change… unless we get M.A.D. (Make A Difference) and take charge of ourselves and the environment our children are raised in!
          </p>
          <div class="text-center">
            <a
              href="/our-mission/"
              class="inline-flex items-center px-8 py-3 bg-fam-red text-white font-normal rounded-sm hover:bg-fam-red-dark transition-colors duration-200 no-underline"
            >
              Read more about our mission
              <svg class="w-4 h-4 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: Stat Phone Use image -->
        <div class="flex justify-center">
          <Image
            src={statPhoneUseImg}
            alt="Parents spend an average of 7 hours and 4 minutes looking at screens every day"
            class="w-full max-w-md"
            widths={[300, 558]}
            sizes="(max-width: 768px) 80vw, 40vw"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Did You Know? Section (dark background) -->
  <section class="relative py-12 md:py-16 bg-gray-900 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={didYouKnowBgImg}
        alt=""
        class="w-full h-full object-cover object-bottom opacity-20"
        widths={[800, 1200]}
        sizes="100vw"
      />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-[30%_70%] gap-8 items-center">
        <!-- Left: Did You Know image -->
        <div class="flex justify-center md:justify-start">
          <Image
            src={didYouKnowImg}
            alt="Did you know?"
            class="w-3/4 md:w-full max-w-[200px]"
            widths={[200, 400, 579]}
            sizes="(max-width: 768px) 60vw, 200px"
          />
        </div>
        <!-- Right: Stat text -->
        <div>
          <p class="text-lg md:text-xl font-normal leading-relaxed mb-3">
            Young people who spend seven hours or more a day on screens are more than twice as likely to be diagnosed with depression or anxiety than those who use screens for an hour a day
          </p>
          <p class="text-xs text-gray-400 font-light">Preventative Medicine Reports 2018</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAMtopia Events & Workshops Section -->
  <section class="relative py-12 md:py-16 bg-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={sunburstBg}
        alt=""
        class="w-full h-full object-cover"
        widths={[800, 1200]}
        sizes="100vw"
      />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <Image
        src={famtopiaLogo}
        alt="FAMtopia Events & Workshops"
        class="mx-auto w-4/5 max-w-xl mb-6"
        widths={[300, 600, 800]}
        sizes="(max-width: 768px) 80vw, 50vw"
      />
      <p class="text-lg md:text-2xl text-fam-text font-light leading-snug mb-8">
        We are committed to educating couples, kids, families, and anyone wanting to learn how to better build and develop the meaningful relationships in their lives.
      </p>
      <a
        href="/events/"
        class="inline-flex items-center px-8 py-3 bg-fam-red text-white font-normal rounded-sm hover:bg-fam-red-dark transition-colors duration-200 no-underline"
      >
        Check out our flagship event series
        <svg class="w-4 h-4 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Jashin Howell Quote / Testimonial (purple grunge background) -->
  <Testimonial
    quote="I'm proud to champion the Family Awareness Movement, and the family of companies, projects, causes and partners we work with to help modern families navigate complex times and complex challenges... together!"
    name="Jashin Howell"
    title="CEO & Co-Founder"
    photo={jashinMedallion}
    background={purpleGrungeBg}
  />

  <!-- Video Section (Vimeo embed) -->
  <section class="py-12 md:py-16 bg-fam-gray">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          class="absolute top-0 left-0 w-full h-full rounded-lg"
          src="https://player.vimeo.com/video/509100210?title=1&portrait=1&byline=1"
          title="FAM Central App Promo Video"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Our Projects Section (dark overlay on home-header bg) -->
  <section class="relative py-16 md:py-24 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={homeHeaderBg}
        alt=""
        class="w-full h-full object-cover"
        widths={[800, 1200]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-black/80"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section intro -->
      <div class="text-center mb-12 px-4 md:px-16">
        <h2 class="text-3xl md:text-4xl font-semibold text-white mb-6">Our Projects</h2>
        <p class="text-white/90 font-light leading-relaxed">
          Cyber bullying, social media pressure, alcohol and drug addiction, pornography, anxiety, depression, and screen addictions are just a few of the issues that might affect our homes today. It's time to take a stand and get M.A.D (Make A Difference)! The FAM Project was created by deeply caring families coupled with renowned family and relationship development professionals. We have collectively built solution based programs that create meaning, direction and offers help as we all try to navigate through these issues seeking to have a strong family unit and strong connections within our families.
        </p>
      </div>

      <!-- Project tiles -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
        <!-- FAM Fun Pass -->
        <div class="bg-white rounded-xl p-8 text-center text-fam-text">
          <Image
            src={famFunPassLogo}
            alt="FAM Fun Pass"
            class="mx-auto w-3/4 max-w-[300px] mb-4"
            widths={[200, 400, 500]}
            sizes="(max-width: 768px) 70vw, 300px"
          />
          <a
            href="https://www.famfunpass.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-6 py-2 bg-fam-red text-white text-sm rounded-sm hover:bg-fam-red-dark transition-colors no-underline mb-4"
          >
            Learn More!
          </a>
          <p class="text-fam-text-light text-lg font-light leading-snug mb-4">
            A subscription based app full of incredible freebies and discounts on things to do, shopping, travel, dining and so much more! All to help better <strong>Connect</strong> your family!
          </p>
          <a href="https://www.famfunpass.com/" target="_blank" rel="noopener noreferrer">
            <Image
              src={famCentralIcon}
              alt="Download FAM Fun Pass on the App Store"
              class="mx-auto w-2/5 max-w-[120px]"
              widths={[120, 300]}
              sizes="120px"
            />
          </a>
        </div>

        <!-- FAM Central -->
        <div class="bg-white rounded-xl p-8 text-center text-fam-text">
          <Image
            src={famCentralLogo}
            alt="FAM Central"
            class="mx-auto w-[87%] max-w-[400px] mb-4"
            widths={[200, 400, 800]}
            sizes="(max-width: 768px) 80vw, 400px"
          />
          <a
            href="https://apps.apple.com/us/app/fam-central/id1548755945"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-6 py-2 bg-fam-red text-white text-sm rounded-sm hover:bg-fam-red-dark transition-colors no-underline mb-4"
          >
            Learn More!
          </a>
          <p class="text-fam-text-light text-lg font-light leading-snug mb-4">
            Our <strong>FAM Central APP</strong> provides education, community, tools and resources to bring all things FAMILY into a "one stop shop" for building stronger, happier and more connected Families!
          </p>
          <a href="https://apps.apple.com/us/app/fam-central/id1548755945" target="_blank" rel="noopener noreferrer">
            <Image
              src={famCentralApp}
              alt="Download FAM Central on the App Store"
              class="mx-auto w-2/5 max-w-[120px]"
              widths={[120, 300]}
              sizes="120px"
            />
          </a>
        </div>
      </div>

      <!-- Read more button -->
      <div class="text-center">
        <a
          href="/projects/"
          class="inline-flex items-center px-8 py-3 bg-fam-red text-white font-normal rounded-sm hover:bg-fam-red-dark transition-colors duration-200 no-underline"
        >
          Read more about our projects
          <svg class="w-4 h-4 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form Section (clouds background) -->
  <CloudsCTA
    heading="Interested in learning more?"
    headingClass="text-3xl md:text-4xl font-semibold text-fam-purple text-center mb-6"
    headingInGrid
  >
    <FormContact buttonText="Let's change the world!" />
  </CloudsCTA>
</BaseLayout>
