---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormWaitlist from '../../components/FormWaitlist.astro';
import { SITE_URL, SOCIAL_LINKS, ABOUT_US_TEXT } from '../../consts';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article, allArticles: articles },
  }));
}

type Props = {
  article: CollectionEntry<'articles'>;
  allArticles: CollectionEntry<'articles'>[];
};

const { article, allArticles } = Astro.props;
const { Content } = await render(article);

// const formattedDate = new Date(article.data.publishDate).toLocaleDateString('en-US', {
//   year: 'numeric',
//   month: 'long',
//   day: 'numeric',
// });

// Get recent posts (excluding current article)
const recentPosts = allArticles
  .filter((a) => a.data.slug !== article.data.slug)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);
---

<BaseLayout
  title={`${article.data.title} — The F.A.M. Project`}
  description={article.data.excerpt}
  image={article.data.featuredImage.src}
>
  <article>
    <!-- Article Header (full-width purple banner) -->
    <div class="bg-fam-purple text-white pt-12 md:pt-16 pb-32 md:pb-40">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="flex flex-wrap justify-center gap-2 mb-4">
          {article.data.categories.map((cat: string) => (
            <span class="inline-block px-3 py-1 text-xs font-semibold text-white/80">
              {cat}
            </span>
          ))}
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">
          {article.data.title}
        </h1>
      </div>
    </div>

    <!-- Floating article card: overlaps purple header above and red CTA below -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-24 md:-mt-32 relative z-10 mb-[-5rem]">
      <div class="bg-white rounded-xl shadow-xl p-6 md:p-10 lg:p-12">
        <div class="flex flex-col lg:flex-row gap-10 lg:gap-12">

          <!-- Left column: Article content -->
          <div class="flex-1 min-w-0 lg:max-w-[65%]">
            <!-- Featured Image -->
            <Image
              src={article.data.featuredImage}
              alt={article.data.title}
              class="w-full rounded-xl mb-8"
              widths={[640, 1024]}
              sizes="(max-width: 768px) 100vw, 768px"
            />

            <!-- Publish date -->
            <!-- <time class="block text-fam-text-light text-sm mb-6" datetime={article.data.publishDate.toISOString()}>
              {formattedDate}
            </time> -->

            <!-- Article Body -->
            <div class="prose prose-lg max-w-none prose-headings:text-fam-text prose-a:text-fam-red prose-a:hover:text-fam-purple prose-a:no-underline prose-img:rounded-lg">
              <Content />
            </div>

            <!-- Author -->
            <div class="mt-10 flex items-start gap-3">
              <div class="w-10 h-10 rounded-full bg-fam-purple/10 flex items-center justify-center text-fam-purple font-bold text-sm flex-shrink-0">
                {article.data.author.split(' ').map((n: string) => n[0]).join('').substring(0, 2)}
              </div>
              <div>
                <p class="text-sm font-semibold text-fam-text">{article.data.author}</p>
                {article.data.authorBio && (
                  <p class="text-xs text-fam-text-light mt-1 leading-relaxed">{article.data.authorBio}</p>
                )}
              </div>
            </div>

            <!-- Back Link -->
            <div class="mt-8 pt-8 border-t border-gray-200">
              <a href="/articles/" class="inline-flex items-center text-fam-red font-semibold no-underline hover:text-fam-purple transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                Back to Articles
              </a>
            </div>
          </div>

          <!-- Right column: Sidebar -->
          <aside class="lg:w-[30%] flex-shrink-0">
            <!-- About Us -->
            <div class="mb-8">
              <h4 class="text-lg font-bold text-fam-text mb-4 border-b-2 border-fam-purple pb-2">About Us</h4>
              <p class="text-sm text-fam-text-light leading-relaxed">
                {ABOUT_US_TEXT}
              </p>
            </div>

            <!-- Social Media Links -->
            <div class="mb-8">
              <div class="flex gap-3">
                <a href={SOCIAL_LINKS.facebook} target="_blank" rel="noopener noreferrer"
                  class="w-10 h-10 rounded-full bg-fam-purple/10 flex items-center justify-center text-fam-purple hover:bg-fam-purple hover:text-white transition-colors"
                  aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/>
                  </svg>
                </a>
                <a href={SOCIAL_LINKS.youtube} target="_blank" rel="noopener noreferrer"
                  class="w-10 h-10 rounded-full bg-fam-purple/10 flex items-center justify-center text-fam-purple hover:bg-fam-purple hover:text-white transition-colors"
                  aria-label="YouTube">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                </a>
                <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer"
                  class="w-10 h-10 rounded-full bg-fam-purple/10 flex items-center justify-center text-fam-purple hover:bg-fam-purple hover:text-white transition-colors"
                  aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                  </svg>
                </a>
              </div>
            </div>

            <!-- Recent Posts -->
            <div class="mb-8">
              <h4 class="text-lg font-bold text-fam-text mb-4 border-b-2 border-fam-purple pb-2">Recent Posts</h4>
              <div class="space-y-4">
                {recentPosts.map((post) => (
                  <div class="group">
                    <a href={`/articles/${post.data.slug}/`} class="block no-underline">
                      <div class="flex gap-3">
                        <div class="w-20 h-16 flex-shrink-0 rounded overflow-hidden bg-gray-100">
                          <Image
                            src={post.data.featuredImage}
                            alt={post.data.title}
                            class="w-full h-full object-cover"
                            widths={[80]}
                            sizes="80px"
                          />
                        </div>
                        <div class="flex-1 min-w-0">
                          <h5 class="text-sm font-semibold text-fam-text group-hover:text-fam-red transition-colors line-clamp-2 leading-tight">
                            {post.data.title}
                          </h5>
                          <span class="text-xs text-fam-red font-medium mt-1 inline-block group-hover:text-fam-purple transition-colors">
                            Read More &raquo;
                          </span>
                        </div>
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </aside>

        </div>
      </div>
    </div>

    <!-- ★ PLACEMENT 10 — Instance 1 (compact): Hero Waitlist CTA (Lite Form) -->
    <div class="bg-fam-red text-white pt-32 pb-16 md:pt-36 md:pb-20">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">Join the FAM Central Waitlist</h2>
        <p class="text-white/90 text-base mb-6">
          Be among the first families to experience the platform. Get early access, event invitations, and the Look Up Challenge guide.
        </p>
        <div class="[&_button]:bg-fam-purple [&_button]:hover:bg-fam-purple-dark">
          <FormWaitlist variant="lite" buttonText="Join the Waitlist →" rowLayout={true} formId="articles-inline" />
        </div>
        <p class="text-white/70 text-xs mt-4">
          *Family is built on trust! We use the most secure systems and promise to never share, rent, or sell your info to 3rd parties. You can opt out of messages at any time, with a click :)
        </p>
      </div>
    </div>
  </article>
</BaseLayout>
