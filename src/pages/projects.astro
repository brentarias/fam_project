---
import BaseLayout from '../layouts/BaseLayout.astro';
import InvestorCTA from '../components/InvestorCTA.astro';
import Testimonial from '../components/Testimonial.astro';
import ZigZagDivider from '../components/ZigZagDivider.astro';
import { Image } from 'astro:assets';
import famFunPassLogo from '../assets/projects/fam-funpass-logo.png';
import famAppImage from '../assets/projects/fam-app-image.png';
import noCostImage from '../assets/projects/no-cost-image.png';
import famCentralLogo from '../assets/projects/fam-central-logo.png';
import famCentralApp from '../assets/projects/fam-central-app.jpg';
import homeHeaderBg from '../assets/hero/home-header.jpg';
import famBikesBg from '../assets/hero/background-fam-bikes-color.jpg';
import sunburstBg from '../assets/hero/sunburst-background.jpg';
import purpleGrungeBg from '../assets/hero/purple-grunge.jpg';
import chrisLangePhoto from '../assets/team/chris-lange.png';
---

<BaseLayout title="Projects — The F.A.M. Project" description="Explore The F.A.M. Project's initiatives including FAM Fun Pass, FAM Central app, vendor partnerships, and fundraising opportunities.">
  <!-- Section 1: Our Projects hero (purple overlay on bikes bg) -->
  <section class="relative py-16 md:py-24 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={famBikesBg}
        alt="Family riding bikes together"
        class="w-full h-full object-cover"
        widths={[800, 1200]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-purple-900/87"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Our Projects</h1>
      <p class="text-lg md:text-xl text-fam-green font-light leading-relaxed mb-4">
        Connection to parents, connection to kids, connection to people is key in helping solve many of our current issues today.
      </p>
      <p class="text-white/80 font-light leading-relaxed">
        So much of our current technology today with smart phones, social media, gaming and other entertainment provides very little real opportunity to authentically and genuinely connect with the people around us. We need to learn to disconnect to connect. Meaning that as we purposefully spend less time using these digital technologies and spend more time doing activities that connect us, we build fulfilling relationships that strengthens our character, gives us more purpose and meaning and provides healthy outlets to deal with many of the common issues we all face today. The FAM Project programs are designed with this mind. Not only to help provide ideas, tools and resources to build an environment and opportunity for better connecting as a family but also to help families save a ton of money while doing it and being able to give back to our community in a meaningful way.
      </p>
    </div>
  </section>

  <!-- Section 2: FAM Fun Pass (sunburst bg) -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={sunburstBg}
        alt=""
        class="w-full h-full object-cover"
        widths={[800, 1200]}
        sizes="100vw"
      />
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <!-- Left: App Image -->
        <div class="flex justify-center">
          <Image
            src={famAppImage}
            alt="FAM Fun Pass app showing family deals and discounts"
            class="w-full max-w-md"
            widths={[300, 500, 762]}
            sizes="(max-width: 768px) 80vw, 40vw"
          />
        </div>
        <!-- Right: Text + CTA -->
        <div>
          <Image
            src={famFunPassLogo}
            alt="FAM Fun Pass"
            class="w-3/4 max-w-[300px] mb-6 mx-auto"
            widths={[200, 400, 500]}
            sizes="(max-width: 768px) 70vw, 300px"
          />
          <h2 class="text-3xl md:text-4xl font-bold text-fam-purple mb-4">We're getting the family together</h2>
          <p class="text-fam-text-light leading-relaxed mb-4">
            An app on both Apple and Android with BIG savings for the whole family, so you can disconnect to connect <em>more often!</em> Have more fun doing more together… face-to-face… in your town or abroad… without breaking the bank!
          </p>
          <h5 class="text-lg font-bold text-fam-gray mb-4">Get it today!</h5>
          <a
            href="https://www.famfunpass.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-8 py-3 bg-fam-red text-white font-semibold rounded-sm hover:bg-fam-red-dark transition-colors duration-200 no-underline"
          >
            Learn more about the FAM Fun Pass!
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Zig-zag divider -->
  <ZigZagDivider />

  <!-- Section 3: FAM Central -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div class="order-2 md:order-1">
          <h2 class="text-3xl md:text-4xl font-bold text-fam-purple mb-4">From Family Fun to Family Connection!</h2>
          <p class="text-fam-text-light leading-relaxed mb-4">
            An app on both Apple and Android this is your family's "one stop shop" for all things family! Educational resources and tools with tips and tricks from the worlds best experts! Find everything you need to build a stronger, happier and more connected family!
          </p>
          <h5 class="text-lg font-bold text-fam-gray mb-4">Get it today!</h5>
          <a
            href="https://apps.apple.com/us/app/fam-central/id1548755945"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-8 py-3 bg-fam-red text-white font-semibold rounded-sm hover:bg-fam-red-dark transition-colors duration-200 no-underline"
          >
            Learn more about FAM Central!
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
        <div class="order-1 md:order-2 flex justify-center">
          <Image
            src={famCentralLogo}
            alt="FAM Central"
            class="w-full max-w-[400px]"
            widths={[200, 400, 800]}
            sizes="(max-width: 768px) 80vw, 400px"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Vendor / Have a product? (green background) -->
  <section class="py-16 md:py-24 text-white bg-fam-green">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <!-- Left: Text + CTA -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold italic mb-6"><em>Have a product or service any fam would love?</em></h2>
          <p class="text-white/90 text-lg leading-relaxed mb-8">
            Drive traffic to your business through our network of families ready to explore new things to do and new ways to learn at no cost to you!
          </p>
          <div class="text-center">
            <a
              href="https://www.famfunpass.com/become-a-vendor/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-8 py-3 bg-fam-red text-white font-semibold rounded-sm hover:bg-fam-red-dark transition-colors duration-200 no-underline"
            >
              Check out our vendor benefits
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
        <!-- Right: No Cost Image -->
        <div class="flex justify-center">
          <Image
            src={noCostImage}
            alt="There's no cost to be a partner"
            class="w-full max-w-xs"
            widths={[250, 400, 600]}
            sizes="(max-width: 768px) 60vw, 300px"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: Chris Lange Testimonial (purple-grunge background) -->
  <Testimonial
    quote="This is really such a unique opportunity for families to find the tools and resources they need to build a stronger, happier and more connected home. All in one central place! We bring it all together for the families and experts to connect on one platform. Our app is more than just great deals, tools and resources, its a community."
    name="Chris Lange"
    title="President & Co-Founder"
    photo={chrisLangePhoto}
    background={purpleGrungeBg}
  />

  <!-- ★ PLACEMENT 8 — Instance 4: Investor Opportunity (Full Form) -->
  <section class="py-16 md:py-24 bg-fam-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <InvestorCTA />
    </div>
  </section>
</BaseLayout>
