---
/**
 * JoinMovementCTA — Tri-choice CTA section (Instance 7).
 *
 * Presents 3 participation paths + a unified full form with checkboxes,
 * wrapped in a CloudsCTA with center layout.
 *
 * Used on: Homepage bottom (Placement 2), Contact page (Placement 9).
 *
 * Props:
 *   headingTag – 'h1' | 'h2' (default 'h2')
 */
import CloudsCTA from './CloudsCTA.astro';
import FormWaitlist from './FormWaitlist.astro';

interface Props {
  headingTag?: 'h1' | 'h2';
}

const { headingTag = 'h2' } = Astro.props;
---

<CloudsCTA
  heading="Join the Movement"
  subheading="There are three powerful ways you can participate."
  headingTag={headingTag}
  layout="center"
  maxWidth="max-w-5xl"
>
  <!-- 3 Option Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <!-- 1. Waitlist -->
    <div class="bg-fam-purple rounded-xl p-6 text-center text-white">
      <div class="text-3xl mb-3">👨‍👩‍👧‍👦</div>
      <h3 class="text-xl font-bold mb-2">Join the FamCentral Waitlist</h3>
      <p class="text-white/80 text-sm leading-relaxed">
        Become part of the growing community of families committed to stronger relationships.
      </p>
    </div>
    <!-- 2. Investor -->
    <div class="bg-fam-purple rounded-xl p-6 text-center text-white flex flex-col items-center">
      <div class="text-3xl mb-3">📈</div>
      <h3 class="text-xl font-bold mb-2">Become an Owner</h3>
      <p class="text-white/80 text-sm leading-relaxed mb-4">
        Invest in the platform that is helping reconnect families across America.
      </p>
      <a
        href="https://wefunder.com/thefamproject"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-auto inline-flex items-center px-5 py-2 bg-white text-fam-purple font-semibold rounded-lg hover:bg-gray-100 transition-colors duration-200 no-underline text-sm"
      >
        Become an Investor
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
    <!-- 3. Expert Faculty -->
    <div class="bg-fam-purple rounded-xl p-6 text-center text-white">
      <div class="text-3xl mb-3">🎓</div>
      <h3 class="text-xl font-bold mb-2">Apply to Join Our Expert Faculty</h3>
      <p class="text-white/80 text-sm leading-relaxed">
        Share your expertise with our community including your content and curriculum.
      </p>
    </div>
  </div>

  <!-- Form in white card (via form slot) -->
  <div slot="form" class="max-w-md mx-auto">
    <div class="bg-white rounded-xl p-8 text-fam-text">
      <FormWaitlist
        variant="full"
        buttonText="Join the Waitlist"
        buttonClass="bg-fam-red hover:bg-fam-red-dark"
      />
    </div>
  </div>
</CloudsCTA>
