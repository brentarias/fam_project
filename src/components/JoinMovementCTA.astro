---
/**
 * JoinMovementCTA — Tri-choice CTA section (Instance 7).
 *
 * Presents 3 participation paths + a unified full form with checkboxes.
 * Used on: Homepage bottom (Placement 4), Contact page (Placement 9).
 *
 * Props:
 *   compact    – When true, renders a compact footer-friendly variant
 *                with a lite form + text links instead of the full layout.
 *   headingTag – 'h1' | 'h2' (default 'h2')
 */
import FormWaitlist from './FormWaitlist.astro';
import CloudsCTA from './CloudsCTA.astro';

interface Props {
  compact?: boolean;
  headingTag?: 'h1' | 'h2';
}

const { compact = false, headingTag = 'h2' } = Astro.props;
const HeadingTag = headingTag;
---

{compact ? (
  <!-- Compact variant for footer: lite form + action links -->
  <div class="join-movement-compact">
    <h4 class="text-sm font-bold text-white mb-3">Join the Movement</h4>
    <FormWaitlist variant="lite" buttonText="Join the Waitlist" buttonClass="bg-fam-red hover:bg-fam-red-dark" />
    <div class="mt-3 space-y-1">
      <a
        href="https://wefunder.com/thefamproject"
        target="_blank"
        rel="noopener noreferrer"
        class="block text-sm text-fam-green hover:text-fam-purple-soft no-underline transition-colors"
      >
        Become an Investor →
      </a>
      <a
        href="/contact/"
        class="block text-sm text-fam-green hover:text-fam-purple-soft no-underline transition-colors"
      >
        Apply as Expert →
      </a>
    </div>
  </div>
) : (
  <!-- Full variant: 3 option cards + full form -->
  <section class="py-16 md:py-24 bg-fam-purple text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <HeadingTag class="text-3xl md:text-4xl font-bold mb-4">Join the Movement</HeadingTag>
        <p class="text-lg text-white/90 font-light">There are three powerful ways you can participate.</p>
      </div>

      <!-- 3 Option Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <!-- 1. Waitlist -->
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center border border-white/20">
          <div class="text-3xl mb-3">👨‍👩‍👧‍👦</div>
          <h3 class="text-xl font-bold mb-2">Join the FamCentral Waitlist</h3>
          <p class="text-white/80 text-sm leading-relaxed">
            Become part of the growing community of families committed to stronger relationships.
          </p>
        </div>
        <!-- 2. Investor -->
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center border border-white/20">
          <div class="text-3xl mb-3">📈</div>
          <h3 class="text-xl font-bold mb-2">Become an Owner</h3>
          <p class="text-white/80 text-sm leading-relaxed">
            Invest in the platform that is helping reconnect families across America.
          </p>
        </div>
        <!-- 3. Expert Faculty -->
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center border border-white/20">
          <div class="text-3xl mb-3">🎓</div>
          <h3 class="text-xl font-bold mb-2">Apply to Join Our Expert Faculty</h3>
          <p class="text-white/80 text-sm leading-relaxed">
            Share your expertise with our community including your content and curriculum.
          </p>
        </div>
      </div>

      <!-- Single form with checkboxes to self-select -->
      <div class="max-w-md mx-auto bg-white rounded-xl p-8 text-fam-text">
        <FormWaitlist
          variant="full"
          buttonText="Join the Waitlist"
          buttonClass="bg-fam-red hover:bg-fam-red-dark"
        />
        <div class="mt-4 text-center">
          <a
            href="https://wefunder.com/thefamproject"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-2.5 bg-fam-purple text-white font-semibold rounded-lg hover:bg-fam-purple-dark transition-colors duration-200 no-underline text-sm"
          >
            Become an Investor
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
)}
