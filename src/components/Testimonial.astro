---
interface Props {
  quote: string;
  name: string;
  title: string;
  photo?: string;
}

const { quote, name, title, photo } = Astro.props;
---

<blockquote class="bg-fam-cream rounded-2xl p-8 md:p-12 border-l-4 border-fam-orange">
  <svg class="w-10 h-10 text-fam-orange/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
  </svg>
  <p class="text-lg md:text-xl text-fam-neutral-dark italic leading-relaxed mb-6">
    "{quote}"
  </p>
  <footer class="flex items-center gap-4">
    {photo && (
      <img src={photo} alt={`${name}`} class="w-12 h-12 rounded-full object-cover" />
    )}
    <div>
      <cite class="not-italic font-semibold text-fam-text block">{name}</cite>
      <span class="text-sm text-fam-text-light">{title}</span>
    </div>
  </footer>
</blockquote>
