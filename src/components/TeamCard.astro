---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  title: string;
  bio: string;
  photo: ImageMetadata;
}

const { name, title, bio, photo } = Astro.props;
---

<div class="bg-white rounded-xl shadow-sm overflow-hidden text-center p-6 hover:shadow-md transition-shadow duration-300">
  <div class="w-34 h-34 rounded-full mx-auto mb-4 bg-fam-purple flex items-center justify-center">
    <Image
      src={photo}
      alt={`${name} — ${title}`}
      class="w-32 h-32 rounded-full object-cover"
      width={256}
      height={256}
    />
  </div>
  <h3 class="text-lg font-bold text-fam-green">{name}</h3>
  <p class="text-sm text-fam-orange font-medium mb-3">{title}</p>
  <p class="text-sm text-fam-text-light leading-relaxed">{bio}</p>
</div>
