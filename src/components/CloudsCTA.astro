---
/**
 * CloudsCTA — Shared clouds-background CTA section.
 *
 * A reusable section with a clouds background image that arranges
 * content and an optional form in one of three layouts:
 *
 *   - left:   content (default slot) on the left, form on the right
 *   - right:  form on the left, content (default slot) on the right
 *   - center: title/subtitle at top, then content centered, then form centered below
 *
 * The form can be provided in two ways:
 *   1. **Prop-driven (preferred):** Set `formVariant` and optional form* props
 *      to render an embedded FormWaitlist automatically.
 *   2. **Slot-based (escape hatch):** Pass a `form` named slot for custom
 *      form markup. The slot takes precedence if both are provided.
 *
 * Props:
 *   heading          – main heading text
 *   subheading       – optional subheading below the heading
 *   headingTag       – 'h1' | 'h2' (default 'h2')
 *   layout           – 'left' | 'right' | 'center' (default 'left')
 *   sectionClass     – extra classes on the <section> (e.g. 'flex-1')
 *   maxWidth         – container max-width class (default 'max-w-6xl')
 *   headingClass     – classes for heading element
 *   subheadingClass  – classes for subheading paragraph
 *
 *   formVariant      – 'lite' | 'full' — enables the embedded FormWaitlist
 *   formButtonText   – CTA button label (default 'Join the Waitlist →')
 *   formPreChecked   – Array of checkbox values to pre-check (full variant)
 *   formButtonClass  – Override button color classes
 *   formRowLayout    – When true, lite form renders inputs in a row
 *
 * Slots:
 *   (default)  – content area (copy, benefits lists, etc.)
 *   form       – override slot for a custom form component
 */
import { Image } from 'astro:assets';
import cloudsBg from '../assets/hero/clouds.jpg';
import FormWaitlist from './FormWaitlist.astro';

interface Props {
  heading?: string;
  subheading?: string;
  headingTag?: 'h1' | 'h2';
  layout?: 'left' | 'right' | 'center';
  sectionClass?: string;
  maxWidth?: string;
  headingClass?: string;
  subheadingClass?: string;
  formVariant?: 'lite' | 'full';
  formButtonText?: string;
  formPreChecked?: ('parent' | 'business' | 'investor' | 'expert')[];
  formButtonClass?: string;
  formRowLayout?: boolean;
}

const {
  heading,
  subheading,
  headingTag = 'h2',
  layout = 'left',
  sectionClass = '',
  maxWidth = 'max-w-6xl',
  headingClass = 'text-3xl md:text-4xl font-bold text-fam-purple text-center mb-4',
  subheadingClass = 'text-xl md:text-2xl text-fam-text-light text-center mb-8',
  formVariant,
  formButtonText,
  formPreChecked = [],
  formButtonClass,
  formRowLayout = false,
} = Astro.props;

const HeadingTag = headingTag;
const isCenter = layout === 'center';
const hasFormSlot = Astro.slots.has('form');
const showForm = hasFormSlot || !!formVariant;
---

<section class:list={['relative py-16 md:py-24 overflow-hidden', sectionClass]}>
  <div class="absolute inset-0 z-0">
    <Image
      src={cloudsBg}
      alt=""
      class="w-full h-full object-fill"
      widths={[800, 1200]}
      sizes="100vw"
    />
  </div>
  <div class:list={['relative z-10 mx-auto px-4 sm:px-6 lg:px-8', maxWidth]}>
    {heading && <HeadingTag class={headingClass}>{heading}</HeadingTag>}
    {subheading && <p class={subheadingClass}>{subheading}</p>}

    {isCenter ? (
      <!-- Center layout: content stacked above form, form centered at max-w-md -->
      <div>
        <slot />
        {showForm && (
          <div class="mt-8 max-w-md mx-auto">
            {hasFormSlot ? (
              <slot name="form" />
            ) : (
              <FormWaitlist
                variant={formVariant!}
                buttonText={formButtonText}
                preChecked={formPreChecked}
                buttonClass={formButtonClass}
                rowLayout={formRowLayout}
              />
            )}
          </div>
        )}
      </div>
    ) : layout === 'right' ? (
      <!-- Right layout: form on left, content on right -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16 items-start">
        {showForm && (
          <div>
            {hasFormSlot ? (
              <slot name="form" />
            ) : (
              <FormWaitlist
                variant={formVariant!}
                buttonText={formButtonText}
                preChecked={formPreChecked}
                buttonClass={formButtonClass}
                rowLayout={formRowLayout}
              />
            )}
          </div>
        )}
        <div>
          <slot />
        </div>
      </div>
    ) : (
      <!-- Left layout (default): content on left, form on right -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16 items-start">
        <div>
          <slot />
        </div>
        {showForm && (
          <div>
            {hasFormSlot ? (
              <slot name="form" />
            ) : (
              <FormWaitlist
                variant={formVariant!}
                buttonText={formButtonText}
                preChecked={formPreChecked}
                buttonClass={formButtonClass}
                rowLayout={formRowLayout}
              />
            )}
          </div>
        )}
      </div>
    )}
  </div>
</section>
