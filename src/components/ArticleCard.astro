---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  slug: string;
  categories: string[];
  excerpt: string;
  featuredImage: ImageMetadata;
}

const { title, slug, categories, excerpt, featuredImage } = Astro.props;
---

<article class="group bg-white rounded-xl shadow-sm overflow-hidden hover:shadow-md transition-shadow duration-300 flex flex-col">
  <a href={`/articles/${slug}/`} class="block no-underline">
    <Image
      src={featuredImage}
      alt={title}
      class="w-full h-48 object-cover"
      widths={[400, 600]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
    />
  </a>
  <div class="p-5 flex flex-col flex-1">
    <span class="inline-block self-start px-3 py-1 text-xs font-semibold text-fam-gray bg-fam-gray/10 rounded-full mb-3">
      {categories[0]}
    </span>
    <h3 class="text-lg font-bold text-fam-text mb-2 leading-snug">
      <a href={`/articles/${slug}/`} class="no-underline text-fam-green group-hover:text-fam-purple transition-colors">
        {title}
      </a>
    </h3>
    <p class="text-sm text-fam-text-light mb-4 flex-1 line-clamp-3">{excerpt}</p>
    <a
      href={`/articles/${slug}/`}
      class="self-start inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-fam-red rounded hover:bg-fam-red-dark no-underline transition-colors"
    >
      Read More
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
