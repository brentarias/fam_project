---
import { Image } from 'astro:assets';
import { NAV_LINKS } from '../consts';
import logoImage from '../assets/logos/fam-logo-circle.png';

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="bg-white shadow-sm sticky top-0 z-50 overflow-visible">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo (oversized, overflows below header) -->
      <a id="logo-link" href="/" class="relative z-[51] flex items-center gap-2 no-underline self-start mt-1">
        <Image
          id="logo-img"
          src={logoImage}
          alt="The F.A.M. Project"
          class="h-24 md:h-32 w-auto drop-shadow-md"
          widths={[80, 112, 200]}
          sizes="112px"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        {NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors duration-200 no-underline border-b-2 pb-1',
              currentPath.startsWith(link.href)
                ? 'text-fam-orange border-fam-orange'
                : 'text-fam-neutral-dark border-transparent hover:text-fam-purple hover:border-fam-purple',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/#hero-form"
          class="inline-flex items-center px-5 py-2 text-sm font-semibold text-white bg-fam-red rounded-full hover:bg-fam-red-dark transition-colors duration-200 no-underline"
        >
          Join the Waitlist
        </a>
      </nav>

      <!-- Mobile Hamburger Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex items-center justify-center w-10 h-10 text-fam-gray"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-gray-100">
    <nav class="px-4 py-4 space-y-2" aria-label="Mobile navigation">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'mobile-nav-link block px-4 py-3 text-base font-medium rounded-lg transition-colors duration-200 no-underline',
            currentPath.startsWith(link.href)
              ? 'text-fam-orange bg-fam-neutral-light'
              : 'text-fam-neutral-dark hover:text-fam-purple hover:bg-fam-neutral-light',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/#hero-form"
        class="mobile-nav-link block w-full text-center px-4 py-3 text-base font-semibold text-white bg-fam-red rounded-lg hover:bg-fam-red-dark transition-colors duration-200 no-underline mt-4"
      >
        Join the Waitlist
      </a>
    </nav>
  </div>
</header>

<style>
  /* Smooth transition for logo shrink-on-scroll */
  #logo-img {
    transition: height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Shrunk state: logo fits inside header */
  #site-header.scrolled #logo-img {
    height: 3.5rem; /* 48px – comfortable inside h-16 (64px) header on mobile */
  }

  @media (min-width: 768px) {
    #site-header.scrolled #logo-img {
      height: 4.25rem; /* 60px – comfortable inside h-20 (80px) header on desktop */
    }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    if (isOpen) {
      menu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    } else {
      menu?.classList.remove('hidden');
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
    }
  });

  // Close mobile menu on navigation
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');
  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Shrink logo medallion on scroll
  const siteHeader = document.getElementById('site-header');

  function handleScroll() {
    if (window.scrollY > 0) {
      siteHeader?.classList.add('scrolled');
    } else {
      siteHeader?.classList.remove('scrolled');
    }
  }

  // Set initial state (handles refresh mid-page)
  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });
</script>
