---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  subtitle?: string;
  backgroundImage: ImageMetadata;
  backgroundAlt?: string;
  overlayClass?: string;
  maxWidth?: string;
}

const {
  title,
  subtitle,
  backgroundImage,
  backgroundAlt = '',
  overlayClass = 'bg-fam-blue/70',
  maxWidth = 'max-w-4xl',
} = Astro.props;
---

<section class="relative min-h-[500px] md:min-h-[600px] flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <Image
    src={backgroundImage}
    alt={backgroundAlt}
    class="absolute inset-0 w-full h-full object-cover"
    widths={[640, 1024, 1920]}
    sizes="100vw"
    loading="eager"
  />
  <!-- Overlay -->
  <div class:list={['absolute inset-0', overlayClass]}></div>

  <!-- Content -->
  <div class:list={['relative z-10 mx-auto px-4 sm:px-6 lg:px-8 text-center text-white py-16 w-full', maxWidth]}>
    {title && (
      <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">
        {title}
      </h1>
    )}
    {subtitle && (
      <p class="text-lg md:text-xl text-gray-200 mb-8 max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}
    <slot />
  </div>
</section>
