---
/**
 * FormWaitlist — Unified waitlist form with lite/full variants.
 *
 * All instances feed into a single mailing list. The full variant
 * adds optional phone + role-segmenting checkboxes.
 *
 * Props:
 *   variant      – 'lite' | 'full' (default 'lite')
 *   buttonText   – CTA button label (default 'Join the Waitlist →')
 *   preChecked   – Array of checkbox values to pre-check (full variant only)
 *                  Valid values: 'parent', 'business', 'investor', 'expert'
 *   rowLayout    – When true, lite form renders inputs in a row (for hero/banner)
 *   buttonClass  – Override button color classes
 *   theme        – 'light' | 'dark' (default 'light'). Use 'dark' when the form
 *                  sits on a dark background so legend/label text remains legible.
 *   formId       – Identifies this placement for conversion tracking (e.g. 'index-hero')
 */
import SuccessToast from './SuccessToast.astro';

interface Props {
  variant?: 'lite' | 'full';
  buttonText?: string;
  preChecked?: ('parent' | 'business' | 'investor' | 'expert')[];
  rowLayout?: boolean;
  buttonClass?: string;
  theme?: 'light' | 'dark';
  formId?: string;
}

const {
  variant = 'lite',
  buttonText = 'Join the Waitlist →',
  preChecked = [],
  rowLayout = false,
  buttonClass = 'bg-fam-red hover:bg-fam-red-dark',
  theme = 'light',
  formId,
} = Astro.props;

const isDark = theme === 'dark';
const legendClass = isDark ? 'text-white/80' : 'text-gray-600';
const legendSubClass = isDark ? 'text-white/50' : 'text-gray-400';
const labelClass = isDark ? 'text-white' : 'text-gray-700';

const isFull = variant === 'full';

const checkboxes = [
  { value: 'parent', label: 'Parent / Family Member' },
  { value: 'business', label: 'Business Owner' },
  { value: 'investor', label: 'Interested in Investing' },
  { value: 'expert', label: 'Expert / Content Creator' },
];
---

<div class="form-waitlist-wrapper">
  {isFull ? (
    <!-- Full variant: stacked layout with optional phone + checkboxes -->
    <form class="stubbed-form space-y-4" data-button-text={buttonText} novalidate>
      <input type="hidden" name="campaign" value="famcentral-prelaunch" />
      {formId && <input type="hidden" name="form_id" value={formId} />}
      <input
        type="text"
        name="name"
        placeholder="Name"
        required
        class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
      />
      <input
        type="email"
        name="email"
        placeholder="Email"
        required
        class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
      />
      <input
        type="tel"
        name="phone"
        placeholder="Phone (optional)"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
      />
      <!-- Role checkboxes -->
      <fieldset class="space-y-2">
        <legend class:list={['text-sm font-medium mb-1', legendClass]}>I am a… <span class:list={['font-normal', legendSubClass]}>(select all that apply)</span></legend>
        {checkboxes.map((cb) => (
          <label class:list={['flex items-center gap-2 cursor-pointer text-sm', labelClass]}>
            <input
              type="checkbox"
              name="role"
              value={cb.value}
              checked={preChecked.includes(cb.value as any)}
              class="w-4 h-4 rounded border-gray-300 text-fam-purple focus:ring-fam-purple"
            />
            {cb.label}
          </label>
        ))}
      </fieldset>
      <button
        type="submit"
        class:list={['w-full px-6 py-3 text-white font-semibold rounded-lg transition-colors duration-200', buttonClass]}
      >
        {buttonText}
      </button>
    </form>
  ) : (
    <!-- Lite variant: name + email -->
    <form class:list={['stubbed-form flex flex-col gap-3', rowLayout && 'lg:flex-row']} data-button-text={buttonText} novalidate>
      <input type="hidden" name="campaign" value="famcentral-prelaunch" />
      {formId && <input type="hidden" name="form_id" value={formId} />}
      <input
        type="text"
        name="name"
        placeholder="Name"
        required
        class="flex-1 min-w-0 px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
      />
      <input
        type="email"
        name="email"
        placeholder="Email"
        required
        class="flex-1 min-w-0 px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
      />
      <button
        type="submit"
        class:list={['px-6 py-3 text-white font-semibold rounded-lg transition-colors duration-200 whitespace-nowrap', buttonClass]}
      >
        {buttonText}
      </button>
    </form>
  )}
  <SuccessToast />
</div>

<script>
  const GHL_WEBHOOK = 'https://services.leadconnectorhq.com/hooks/535RAqUk5Kkq0zbDXiFC/webhook-trigger/65b7cd75-5b8a-404b-8045-2d3c424aba81';

  document.querySelectorAll('.form-waitlist-wrapper .stubbed-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const emailInput = formEl.querySelector('input[type="email"]') as HTMLInputElement;
      const nameInput = formEl.querySelector('input[name="name"]') as HTMLInputElement;
      if (!nameInput.checkValidity()) {
        nameInput.reportValidity();
        return;
      }
      if (!emailInput.checkValidity()) {
        emailInput.reportValidity();
        return;
      }
      const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';
      try {
        const formData = new FormData(formEl);
        const payload: Record<string, string | string[]> = {};
        formData.forEach((value, key) => {
          if (key === 'role') {
            if (!payload[key]) payload[key] = [];
            (payload[key] as string[]).push(value as string);
          } else {
            payload[key] = value as string;
          }
        });
        await fetch(GHL_WEBHOOK, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        formEl.reset();
        (window as any).__showToast?.(formEl);
      } catch {
        alert('Something went wrong. Please try again.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = formEl.dataset.buttonText || 'Join the Waitlist →';
      }
    });
  });
</script>
