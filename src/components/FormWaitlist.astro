---
/**
 * FormWaitlist — Unified waitlist form with lite/full variants.
 *
 * All instances feed into a single mailing list. The full variant
 * adds optional phone + role-segmenting checkboxes.
 *
 * Props:
 *   variant      – 'lite' | 'full' (default 'lite')
 *   buttonText   – CTA button label (default 'Join the Waitlist →')
 *   preChecked   – Array of checkbox values to pre-check (full variant only)
 *                  Valid values: 'parent', 'business', 'investor', 'expert'
 *   rowLayout    – When true, lite form renders inputs in a row (for hero/banner)
 *   buttonClass  – Override button color classes
 *   theme        – 'light' | 'dark' (default 'light'). Use 'dark' when the form
 *                  sits on a dark background so legend/label text remains legible.
 *   formId       – Identifies this placement for conversion tracking (e.g. 'index-hero')
 */
import SuccessToast from './SuccessToast.astro';

interface Props {
  variant?: 'lite' | 'full';
  buttonText?: string;
  preChecked?: ('parent' | 'business' | 'investor' | 'expert')[];
  rowLayout?: boolean;
  buttonClass?: string;
  theme?: 'light' | 'dark';
  formId?: string;
}

const {
  variant = 'lite',
  buttonText = 'Join the Waitlist →',
  preChecked = [],
  rowLayout = false,
  buttonClass = 'bg-fam-red hover:bg-fam-red-dark',
  theme = 'light',
  formId,
} = Astro.props;

const isDark = theme === 'dark';
const legendClass = isDark ? 'text-white/80' : 'text-gray-600';
const legendSubClass = isDark ? 'text-white/50' : 'text-gray-400';
const labelClass = isDark ? 'text-white' : 'text-gray-700';

const isFull = variant === 'full';

const checkboxes = [
  { value: 'parent', label: 'Parent / Family Member' },
  { value: 'business', label: 'Business Owner' },
  // { value: 'investor', label: 'Interested in Investing' },
  { value: 'expert', label: 'Expert / Content Creator' },
];
---

<div class="form-waitlist-wrapper">
  {isFull ? (
    <!-- Full variant: stacked layout with optional phone + checkboxes -->
    <form class="stubbed-form space-y-4" data-button-text={buttonText} novalidate>
      <input type="hidden" name="campaign" value="famcentral-prelaunch" />
      {formId && <input type="hidden" name="form_id" value={formId} />}
      <div>
        <input
          type="text"
          name="name"
          placeholder="Name"
          required
          title="Please provide your name"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
        />
      </div>
      <div>
        <input
          type="email"
          name="email"
          placeholder="Email"
          required
          title="Please enter a valid e-mail"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
        />
      </div>
      <div>
        <input
          type="tel"
          name="phone"
          placeholder="Phone (optional)"
          title="Please enter a valid phone number (10–15 digits)"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
        />
        <p class:list={['text-xs italic mt-1', legendClass]}>Include your phone to be first to unlock exclusive FAM deals and founding member rewards.</p>
      </div>
      <!-- Role checkboxes -->
      <fieldset class="space-y-2">
        <legend class:list={['text-sm font-medium mb-1', legendClass]}>I am a… <span class:list={['font-normal', legendSubClass]}>(select all that apply)</span></legend>
        {checkboxes.map((cb) => {
          const hasExtra = cb.value === 'business' || cb.value === 'expert';
          const isChecked = preChecked.includes(cb.value as any);
          return (
            <div>
              <label class:list={['flex items-center gap-2 cursor-pointer text-sm', labelClass]}>
                <input
                  type="checkbox"
                  name="role"
                  value={cb.value}
                  checked={isChecked}
                  class="w-4 h-4 rounded border-gray-300 text-fam-purple focus:ring-fam-purple"
                />
                {cb.label}
              </label>
              {hasExtra && (
                <div
                  class:list={['extra-fields mt-2', !isChecked && 'extra-fields-collapsed']}
                  data-role={cb.value}
                >
                  <div class="pl-6 pt-1 pr-1 pb-1 space-y-2">
                    <div>
                      <input
                        type="text"
                        name={`${cb.value}_website`}
                        placeholder="Website"
                        disabled={!isChecked}
                        title="Please enter a valid website address (e.g. example.com)"
                        class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-sm"
                      />
                    </div>
                    <div>
                      <input
                        type="text"
                        name={`${cb.value}_linkedin`}
                        placeholder="LinkedIn"
                        disabled={!isChecked}
                        title="Please enter a valid website address (e.g. linkedin.com/in/your_name)"
                        class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-sm"
                      />
                    </div>
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </fieldset>
      <!-- Legal consent checkboxes -->
      <div class:list={['legal-consent space-y-3 p-4 rounded-lg border', isDark ? 'bg-white/5 border-white/10' : 'bg-gray-50 border-gray-200']}>
        <label class:list={['flex items-start gap-2 cursor-pointer text-xs leading-relaxed', isDark ? 'text-white/70' : 'text-gray-500']}>
          <input
            type="checkbox"
            name="sms_consent"
            value="true"
            class="w-4 h-4 mt-0.5 rounded border-gray-300 text-fam-purple focus:ring-fam-purple shrink-0"
          />
          <span>By checking this box, I consent to receive SMS messages from <strong>Abundant Holdings LLC</strong>. These messages may include updates, promotions, and reminders. Message frequency varies. Message and data rates may apply. Reply STOP to opt out or HELP for help. Consent is not a condition of purchase. See our <a href="/privacy-policy/" target="_blank" class="underline hover:text-fam-green">Privacy Policy</a> and <a href="/terms-and-conditions/" target="_blank" class="underline hover:text-fam-green">Terms &amp; Conditions</a>.</span>
        </label>
        <label class:list={['flex items-start gap-2 cursor-pointer text-xs leading-relaxed', isDark ? 'text-white/70' : 'text-gray-500']}>
          <input
            type="checkbox"
            name="terms_accepted"
            value="true"
            required
            class="w-4 h-4 mt-0.5 rounded border-gray-300 text-fam-purple focus:ring-fam-purple shrink-0"
          />
          <span>By checking this box, I confirm that I have read and agree to the <a href="/privacy-policy/" target="_blank" class="underline hover:text-fam-green">Privacy Policy</a> and <a href="/terms-and-conditions/" target="_blank" class="underline hover:text-fam-green">Terms &amp; Conditions</a> of <strong>Abundant Holdings LLC</strong>, including how my data will be collected, used, and protected.</span>
        </label>
      </div>
      <button
        type="submit"
        class:list={['w-full px-6 py-3 text-white font-semibold rounded-lg transition-colors duration-200', buttonClass]}
      >
        {buttonText}
      </button>
      <p class:list={['text-xs text-center mt-2', isDark ? 'text-white/40' : 'text-gray-400']}>
        By submitting this form you agree to our <a href="/privacy-policy/" target="_blank" class="underline hover:text-fam-green">Privacy Policy</a> and <a href="/terms-and-conditions/" target="_blank" class="underline hover:text-fam-green">Terms of Service</a>. Your SMS consent is not shared with third parties except SMS service providers.
      </p>
    </form>
  ) : (
    <!-- Lite variant: name + email -->
    <form class:list={['stubbed-form flex flex-col gap-3', rowLayout && 'lg:flex-row']} data-button-text={buttonText} novalidate>
      <input type="hidden" name="campaign" value="famcentral-prelaunch" />
      {formId && <input type="hidden" name="form_id" value={formId} />}
      <div class="flex-1 min-w-0">
        <input
          type="text"
          name="name"
          placeholder="Name"
          required
          title="Please provide your name"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
        />
      </div>
      <div class="flex-1 min-w-0">
        <input
          type="email"
          name="email"
          placeholder="Email"
          required
          title="Please enter a valid e-mail"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-fam-orange focus:border-transparent text-base"
        />
      </div>
      <button
        type="submit"
        class:list={['px-6 py-3 text-white font-semibold rounded-lg transition-colors duration-200 whitespace-nowrap', buttonClass]}
      >
        {buttonText}
      </button>
      <!-- Legal consent checkboxes (hidden until first submit click) -->
      <div class:list={['lite-legal-consent legal-consent-collapsed space-y-3 p-4 rounded-lg border', isDark ? 'bg-white/5 border-white/10' : 'bg-gray-50 border-gray-200']}>
        <label class:list={['flex items-start gap-2 cursor-pointer text-xs leading-relaxed', isDark ? 'text-white/70' : 'text-gray-500']}>
          <input
            type="checkbox"
            name="sms_consent"
            value="true"
            disabled
            class="w-4 h-4 mt-0.5 rounded border-gray-300 text-fam-purple focus:ring-fam-purple shrink-0"
          />
          <span>By checking this box, I consent to receive SMS messages from <strong>Abundant Holdings LLC</strong>. These messages may include updates, promotions, and reminders. Message frequency varies. Message and data rates may apply. Reply STOP to opt out or HELP for help. Consent is not a condition of purchase. See our <a href="/privacy-policy/" target="_blank" class="underline hover:text-fam-green">Privacy Policy</a> and <a href="/terms-and-conditions/" target="_blank" class="underline hover:text-fam-green">Terms &amp; Conditions</a>.</span>
        </label>
        <label class:list={['flex items-start gap-2 cursor-pointer text-xs leading-relaxed', isDark ? 'text-white/70' : 'text-gray-500']}>
          <input
            type="checkbox"
            name="terms_accepted"
            value="true"
            required
            disabled
            class="w-4 h-4 mt-0.5 rounded border-gray-300 text-fam-purple focus:ring-fam-purple shrink-0"
          />
          <span>By checking this box, I confirm that I have read and agree to the <a href="/privacy-policy/" target="_blank" class="underline hover:text-fam-green">Privacy Policy</a> and <a href="/terms-and-conditions/" target="_blank" class="underline hover:text-fam-green">Terms &amp; Conditions</a> of <strong>Abundant Holdings LLC</strong>, including how my data will be collected, used, and protected.</span>
        </label>
      </div>
      <p class:list={['lite-legal-fineprint legal-consent-collapsed text-xs text-center mt-2', isDark ? 'text-white/40' : 'text-gray-400']}>
        By submitting this form you agree to our <a href="/privacy-policy/" target="_blank" class="underline hover:text-fam-green">Privacy Policy</a> and <a href="/terms-and-conditions/" target="_blank" class="underline hover:text-fam-green">Terms of Service</a>. Your SMS consent is not shared with third parties except SMS service providers.
      </p>
    </form>
  )}
  <SuccessToast />
</div>

<style>
  :global(.field-invalid) {
    border-color: #ee2e56 !important;
    box-shadow: 0 0 0 3px rgba(238, 46, 86, 0.25) !important;
  }
  :global(.field-error-msg) {
    color: #ee2e56;
    font-size: 0.75rem;
    margin-top: 0.25rem;
  }
  .extra-fields {
    overflow: hidden;
    max-height: 16rem;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    opacity: 1;
  }
  .extra-fields > div {
    overflow: visible;
  }
  .extra-fields-collapsed {
    max-height: 0;
    opacity: 0;
  }
  :global(.legal-consent-error) {
    background-color: rgb(254 242 242) !important;
    border-color: rgb(252 165 165) !important;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }
  .legal-consent-collapsed {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }
  .legal-consent-expanded {
    max-height: 30rem;
    opacity: 1;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }
</style>

<script>
  const GHL_WEBHOOK = 'https://services.leadconnectorhq.com/hooks/535RAqUk5Kkq0zbDXiFC/webhook-trigger/65b7cd75-5b8a-404b-8045-2d3c424aba81';

  function showError(input: HTMLInputElement, message: string) {
    input.classList.add('field-invalid');
    let msg = input.nextElementSibling as HTMLElement | null;
    if (!msg || !msg.classList.contains('field-error-msg')) {
      msg = document.createElement('p');
      msg.className = 'field-error-msg';
      input.after(msg);
    }
    msg.textContent = message;
  }

  function clearError(input: HTMLInputElement) {
    input.classList.remove('field-invalid');
    const next = input.nextElementSibling;
    if (next?.classList.contains('field-error-msg')) next.remove();
  }

  function validateField(input: HTMLInputElement, strict = false): boolean {
    const value = input.value.trim();
    if (value === '') {
      if (strict && input.required) {
        showError(input, input.title || 'Please check this field.');
        return false;
      }
      clearError(input);
      return true;
    }
    let valid: boolean;
    if (input.type === 'tel') {
      const digits = value.replace(/\D/g, '');
      valid = digits.length >= 10 && digits.length <= 15;
    } else if (input.name.endsWith('_website') || input.name.endsWith('_linkedin')) {
      valid = /^(https?:\/\/)?([a-zA-Z0-9-]+\.)+[a-zA-Z]{2,}(\/\S*)?$/.test(value);
    } else {
      valid = input.checkValidity();
    }
    if (valid) {
      clearError(input);
      return true;
    }
    showError(input, input.title || 'Please check this field.');
    return false;
  }

  function attachFieldValidation(form: Element) {
    form.querySelectorAll<HTMLInputElement>('input:not([type="hidden"]):not([type="checkbox"])').forEach(input => {
      input.addEventListener('blur', () => validateField(input));
      input.addEventListener('input', () => {
        if (input.classList.contains('field-invalid')) validateField(input);
      });
    });
  }

  function applyExtraFields(checkbox: HTMLInputElement) {
    const form = checkbox.closest('form');
    if (!form) return;
    const extra = form.querySelector<HTMLElement>(`.extra-fields[data-role="${checkbox.value}"]`);
    if (!extra) return;
    const inputs = extra.querySelectorAll<HTMLInputElement>('input');
    if (checkbox.checked) {
      extra.classList.remove('extra-fields-collapsed');
      inputs.forEach(i => { i.disabled = false; });
    } else {
      extra.classList.add('extra-fields-collapsed');
      inputs.forEach(i => { i.disabled = true; i.value = ''; });
    }
  }

  document.querySelectorAll<HTMLInputElement>(
    '.form-waitlist-wrapper input[type="checkbox"][name="role"]'
  ).forEach(cb => {
    if (cb.value === 'business' || cb.value === 'expert') {
      cb.addEventListener('change', () => applyExtraFields(cb));
    }
  });

  function showCheckboxError(checkbox: HTMLInputElement, message: string) {
    checkbox.classList.add('field-invalid');
    const label = checkbox.closest('label');
    if (!label) return;
    let msg = label.nextElementSibling as HTMLElement | null;
    if (!msg || !msg.classList.contains('field-error-msg')) {
      msg = document.createElement('p');
      msg.className = 'field-error-msg';
      label.after(msg);
    }
    msg.textContent = message;
    // Tint the consent container
    const container = checkbox.closest('.legal-consent, .lite-legal-consent');
    if (container) {
      container.classList.add('legal-consent-error');
    }
    // Scroll checkbox into view
    checkbox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    checkbox.focus();
  }

  function clearCheckboxError(checkbox: HTMLInputElement) {
    checkbox.classList.remove('field-invalid');
    const label = checkbox.closest('label');
    if (!label) return;
    const next = label.nextElementSibling;
    if (next?.classList.contains('field-error-msg')) next.remove();
    // Revert consent container tint
    const container = checkbox.closest('.legal-consent, .lite-legal-consent');
    if (container) {
      container.classList.remove('legal-consent-error');
    }
  }

  function isLiteForm(form: HTMLFormElement): boolean {
    return !!form.querySelector('.lite-legal-consent');
  }

  function isLiteExpanded(form: HTMLFormElement): boolean {
    const panel = form.querySelector('.lite-legal-consent');
    return !!panel && panel.classList.contains('legal-consent-expanded');
  }

  function expandLiteConsent(form: HTMLFormElement) {
    const panel = form.querySelector('.lite-legal-consent');
    const fineprint = form.querySelector('.lite-legal-fineprint');
    if (!panel) return;
    panel.classList.remove('legal-consent-collapsed');
    panel.classList.add('legal-consent-expanded');
    panel.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach(cb => { cb.disabled = false; });
    if (fineprint) {
      fineprint.classList.remove('legal-consent-collapsed');
      fineprint.classList.add('legal-consent-expanded');
    }
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (btn) btn.textContent = 'Confirm & Join →';
  }

  function collapseLiteConsent(form: HTMLFormElement) {
    const panel = form.querySelector('.lite-legal-consent');
    const fineprint = form.querySelector('.lite-legal-fineprint');
    if (!panel) return;
    panel.classList.add('legal-consent-collapsed');
    panel.classList.remove('legal-consent-expanded');
    panel.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach(cb => { cb.disabled = true; cb.checked = false; });
    if (fineprint) {
      fineprint.classList.add('legal-consent-collapsed');
      fineprint.classList.remove('legal-consent-expanded');
    }
  }

  document.querySelectorAll('.form-waitlist-wrapper .stubbed-form').forEach((form) => {
    attachFieldValidation(form);

    // Live clear for terms checkbox error
    form.querySelectorAll<HTMLInputElement>('input[name="terms_accepted"]').forEach(cb => {
      cb.addEventListener('change', () => { if (cb.checked) clearCheckboxError(cb); });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const nameInput = formEl.querySelector('input[name="name"]') as HTMLInputElement;
      const emailInput = formEl.querySelector('input[type="email"]') as HTMLInputElement;
      const nameOk = validateField(nameInput, true);
      const emailOk = validateField(emailInput, true);
      if (!nameOk || !emailOk) return;

      // Lite variant: first click expands consent, second click submits
      if (isLiteForm(formEl) && !isLiteExpanded(formEl)) {
        expandLiteConsent(formEl);
        return;
      }

      // Validate terms checkbox (required)
      const termsCheckbox = formEl.querySelector('input[name="terms_accepted"]:not([disabled])') as HTMLInputElement | null;
      if (termsCheckbox && !termsCheckbox.checked) {
        showCheckboxError(termsCheckbox, 'You must agree to the Privacy Policy and Terms & Conditions.');
        return;
      }

      const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';
      try {
        const formData = new FormData(formEl);
        const payload: Record<string, string | string[] | boolean> = {};
        formData.forEach((value, key) => {
          if (key === 'role') {
            if (!payload[key]) payload[key] = [];
            (payload[key] as string[]).push(value as string);
          } else {
            payload[key] = value as string;
          }
        });
        // Add consent booleans
        payload.sms_consent = formData.has('sms_consent');
        payload.terms_accepted = formData.has('terms_accepted');

        await fetch(GHL_WEBHOOK, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        formEl.reset();
        formEl.querySelectorAll<HTMLInputElement>('input[type="checkbox"][name="role"]').forEach(cb => {
          if (cb.value === 'business' || cb.value === 'expert') applyExtraFields(cb);
        });
        // Collapse lite consent panel after reset
        if (isLiteForm(formEl)) collapseLiteConsent(formEl);
        (window as any).__showToast?.(formEl);
      } catch {
        alert('Something went wrong. Please try again.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = formEl.dataset.buttonText || 'Join the Waitlist →';
      }
    });
  });
</script>
