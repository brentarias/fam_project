---
import { Image } from 'astro:assets';
import { SOCIAL_LINKS } from '../consts';
import logoImage from '../assets/logos/fam-logo-circle.png';
---

<footer class="relative bg-fam-gray text-white pt-16 md:pt-20">
  <!-- Floating medallion logo -->
  <div class="absolute left-1/2 -translate-x-1/2 -top-6 md:-top-8 z-10">
    <a href="/" class="block">
      <Image
        src={logoImage}
        alt="The F.A.M. Project"
        class="w-24 md:w-32 h-auto drop-shadow-lg"
        widths={[80, 96, 192]}
        sizes="96px"
      />
    </a>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Column 1: Navigate -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-fam-orange mb-4">Navigate</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-fam-green hover:text-fam-purple-soft no-underline transition-colors">Home</a></li>
          <li><a href="/our-fam/" class="text-sm text-fam-green hover:text-fam-purple-soft no-underline transition-colors">Team</a></li>
        </ul>
      </div>

      <!-- Column 3: Follow Us (social) + Logo & Description (was col 1) -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-fam-orange mb-4">Follow Us</h3>
        <div class="flex gap-4 mb-6">
          <a
            href={SOCIAL_LINKS.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="social-medallion"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a
            href={SOCIAL_LINKS.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="social-medallion"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
          <a
            href={SOCIAL_LINKS.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="social-medallion"
            aria-label="YouTube"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 4: Join the Movement (was bottom of col 4) -->
      <!-- ★ PLACEMENT 11 — Instance 7 (compact): Join the Movement -->
      <div class="footer-newsletter">
        <slot name="newsletter" />
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-fam-gray-light">
      <p class="text-sm text-gray-400 text-center">
        &copy; {new Date().getFullYear()} The F.A.M. Project. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  /* Green medallion social icons */
  .social-medallion {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    background-color: var(--color-fam-green);
    color: #fff;
    transition: transform 0.2s ease;
  }
  .social-medallion:hover {
    transform: scale(1.1);
    color: #fff;
  }

  /* Force newsletter form to stack vertically in footer's narrow column */
  .footer-newsletter :global(form) {
    flex-direction: column !important;
  }
</style>
