---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JoinMovementCTA from '../components/JoinMovementCTA.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
}

const { title, description, image, canonicalURL } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} canonicalURL={canonicalURL} />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 flex flex-col">
      <slot />
    </main>
    <Footer>
      <JoinMovementCTA compact slot="newsletter" />
    </Footer>
  </body>
</html>
