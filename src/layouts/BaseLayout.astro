---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
}

const { title, description, image, canonicalURL } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} canonicalURL={canonicalURL} />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 flex flex-col">
      <slot />
    </main>
    <Footer>
      <div slot="newsletter">
        <a href="/" class="text-xl font-bold text-white no-underline hover:text-fam-orange">
          The F.A.M. Project
        </a>
        <p class="mt-4 mb-6 text-sm text-gray-300">
          Strengthening families through education, community events, and resources that bring families closer together.
        </p>
        <a
          href="/contact/"
          class="block w-full text-center px-5 py-2 text-sm font-semibold text-white bg-fam-red hover:bg-fam-red-dark rounded-lg no-underline transition-colors duration-200 mb-3"
        >
          Join the Waitlist
        </a>
        <a
          href="https://wefunder.com/thefamproject"
          target="_blank"
          rel="noopener noreferrer"
          class="block text-sm text-fam-green hover:text-fam-purple-soft no-underline transition-colors"
        >
          Follow us on WeFunder →
        </a>
      </div>
    </Footer>
  </body>
</html>
